      "types": "./dist/hooks/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch"
  },
  "dependencies": {
    "@rsksmart/bridges-core-sdk": "^0.5.0",
    "@rsksmart/flyover-sdk": "^1.8.0",
    "@tanstack/react-query": "^5.90.21",
    "viem": "^2.46.3",
    "wagmi": "^3.5.0",
    "zustand": "^5.0.11"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "tsup": "^8.5.1",
    "typescript": "^5"
  }
