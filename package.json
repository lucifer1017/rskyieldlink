{
  "name": "rskyieldlink",
  "version": "0.1.0",
  "private": true,
  "description": "Yield-Link: Direct Bitcoin to DeFi yield on Rootstock",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
